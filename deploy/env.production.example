APP_NAME=LicoPOS
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=America/La_Paz
APP_URL=https://licos.fadi.com.bo

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=fadi_licos
DB_USERNAME=fadi_licos
DB_PASSWORD=CAMBIAR_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
CACHE_PREFIX=licos_

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Conexión a paybol_fadi (solo si necesitas importar datos)
# PAYBOL_DB_HOST=localhost
# PAYBOL_DB_DATABASE=fadi_paybol
# PAYBOL_DB_USERNAME=fadi_paybol
# PAYBOL_DB_PASSWORD=CAMBIAR_PASSWORD
